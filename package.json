{
  "name": "hifz",
  "version": "1.0.0",
  "private": true,
  "description": "نظام إدارة حلقات تحفيظ القرآن الكريم — معهد نور القرآن (دمشق)",
  "scripts": {
    "serve": "node server.js",
    "test": "node tests/e2e.test.js",
    "test:e2e": "node tests/e2e.test.js",
    "lint": "eslint \"js/**/*.js\" server.js",
    "lint:fix": "eslint --fix \"js/**/*.js\" server.js",
    "format": "prettier --write \"**/*.{js,json,html,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,html,css,md}\"",
    "deploy": "firebase deploy --only hosting,database",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only database"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
